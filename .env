# Copy to .env and set values. Used by the API (settings.py) and optionally by admin_ui.

# ---- Required for API ----
MONGO_URI=mongodb://localhost:27017/saas_db
JWT_SECRET=change-me-in-production

# ---- CORS ----
# Comma-separated origins for admin UI (e.g. Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# ---- Optional: Redis cache ----
# If set, tenant settings are cached (5 min TTL). Reduces DB load for multi-tenant.
# If unset, cache is disabled (no Redis required).
# REDIS_URI=redis://localhost:6379/0

# ---- Optional: bootstrap first super admin ----
# Create on first run if no super_admin user exists.
# BOOT_SUPER_ADMIN_EMAIL=admin@example.com
# BOOT_SUPER_ADMIN_PASSWORD=SecurePassword123

# ---- Optional: scheduler ----
# Cron jobs, promotions, followups, reports
SCHEDULER_ENABLED=true

# ---- Optional: JWT ----
# JWT_EXP_MINUTES=120

# ---- Optional: cookies (Swagger / same-origin) ----
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
AI_ENABLED=false
VITE_CATALOG_WHATSAPP_NUMBER=+919999999999



# S3 BUCKET SETTINGS (for reports and uploads, e.g. for WhatsApp media)

DEFAULT_REGION=us-east-1
S3_ENABLED=false

REPORTS_BUCKET=demo-reports-bucket
UPLOADS_BUCKET=demo-uploads-bucket

REPORTS_PREFIX=reports/
UPLOADS_PREFIX=uploads/